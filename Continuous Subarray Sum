class Solution:
    def checkSubarraySum(self, nums: List[int], k: int) -> bool:
        if len(nums) < 2:
            return False
        myMap = {0:-1}
        prefix_sum = []  
        running_sum = 0
        for i in range(len(nums)):
            running_sum += nums[i]
            prefix_sum.append(running_sum) 

            rem = running_sum % k
            if rem in myMap:
                if i - myMap[rem] > 1:
                    return True
            else:
                myMap[running_sum % k] = i

        return False
        
